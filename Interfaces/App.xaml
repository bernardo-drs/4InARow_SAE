<Application x:Class="Interfaces.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Interfaces"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             StartupUri="MainWindow.xaml"
             ShutdownMode="OnExplicitShutdown">
    
    
    <Application.Resources>
        <SolidColorBrush x:Key="BackgroundColor" Color="#20114a"/>
        <SolidColorBrush x:Key="TextColor"       Color="#FFFFFF"/>
        <SolidColorBrush x:Key="AccentColor"     Color="#7a6fb0"/>
        <SolidColorBrush x:Key="ButtonTextColor" Color="#FFFFFF"/>
        
        <!-- Toute les tailles d'écriture différente -->
        <sys:Double x:Key="FontSize10">10</sys:Double>
        <sys:Double x:Key="FontSize12">12</sys:Double>
        <sys:Double x:Key="FontSize15">15</sys:Double>
        <sys:Double x:Key="FontSize17">17</sys:Double>
        <sys:Double x:Key="FontSize20">20</sys:Double>
        <sys:Double x:Key="FontSize22">22</sys:Double>
        <sys:Double x:Key="FontSize30">30</sys:Double>
        <sys:Double x:Key="FontSize35">35</sys:Double>
        <sys:Double x:Key="FontSize47">47</sys:Double>
        
    </Application.Resources>
    
    
</Application>
