<Page x:Class="Interfaces.Pages.ChoixModeJeu"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Interfaces.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="210" d:DesignWidth="414"
      Title="ChoixModeJeu" FontFamily="Agency FB">

    <Border Background="#8176A8" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="11*"/>
                <RowDefinition Height="66*"/>
                <RowDefinition Height="7*"/>
                <RowDefinition Height="32*"/>
                <RowDefinition Height="7*"/>
                <RowDefinition Height="31*"/>
                <RowDefinition Height="13*"/>
                <RowDefinition Height="35*"/>
                <RowDefinition Height="7*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="87*"/>
                    <ColumnDefinition Width="214*"/>
                    <ColumnDefinition Width="87*"/>
                </Grid.ColumnDefinitions>

                <Viewbox Grid.Column="1">
                    <TextBlock Foreground="White" TextAlignment="Center">
                        Quel mode de jeu
                        <LineBreak />
                        souhaitez-vous faire ?
                    </TextBlock>
                </Viewbox>

            </Grid>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="98*"/>
                    <ColumnDefinition Width="102*"/>
                    <ColumnDefinition Width="16*"/>
                    <ColumnDefinition Width="102*"/>
                    <ColumnDefinition Width="98*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="brdClass" Grid.Column="1" CornerRadius="10" Background="#20114A" BorderBrush="White" BorderThickness="2">
                    <Viewbox>
                        <Button x:Name="btnClassique" Background="Transparent" OverridesDefaultStyle="True" Click="btnClassique_Click">
                            <Button.Template>
                                <ControlTemplate>
                                    <TextBlock Foreground="White">
    Classique
                                    </TextBlock>
                                </ControlTemplate>
                            </Button.Template>

                        </Button>
                    </Viewbox>
                </Border>

                <Border x:Name="brdChall" Grid.Column="3" CornerRadius="10" Background="#20114A" BorderBrush="White" BorderThickness="0">
                    <Viewbox>
                        <Button x:Name="btnChallenge" Background="Transparent" OverridesDefaultStyle="True" BorderThickness="0" Click="btnChallenge_Button_Click">
                            <Button.Template>
                                <ControlTemplate>
                                    <TextBlock Foreground="White">
Challenge
                                    </TextBlock>
                                </ControlTemplate>
                            </Button.Template>

                        </Button>
                    </Viewbox>
                </Border>


            </Grid>

            <Grid Grid.Row="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="121*"/>
                    <ColumnDefinition Width="78*"/>
                    <ColumnDefinition Width="19*"/>
                    <ColumnDefinition Width="78*"/>
                    <ColumnDefinition Width="118*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="brd3V" Grid.Column="1" CornerRadius="10" Background="#605786" BorderBrush="White" BorderThickness="0">
                    <Viewbox>
                        <Button x:Name="btn3V" Background="Transparent" OverridesDefaultStyle="True" BorderThickness="0" IsEnabled="False">
                            <Button.Template>
                                <ControlTemplate>
                                    <TextBlock Foreground="White">
3 victoires
                                    </TextBlock>
                                </ControlTemplate>
                            </Button.Template>

                        </Button>
                    </Viewbox>
                </Border>

                <Border x:Name="brd5V" Grid.Column="3" CornerRadius="10" Background="#605786" BorderBrush="White" BorderThickness="0">
                    <Viewbox>
                        <Button x:Name="btn5V" Background="Transparent" OverridesDefaultStyle="True" BorderThickness="0" IsEnabled="False">
                            <Button.Template>
                                <ControlTemplate>
                                    <TextBlock Foreground="White">
5 victoires
                                    </TextBlock>
                                </ControlTemplate>
                            </Button.Template>

                        </Button>
                    </Viewbox>
                </Border>
            </Grid>

            <Grid Grid.Row="7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="64*"/>
                    <ColumnDefinition Width="77*"/>
                    <ColumnDefinition Width="64*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="1" CornerRadius="10" Background="#20114A">
                    <Viewbox>
                        <Button Background="Transparent" OverridesDefaultStyle="True" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate>
                                    <TextBlock Foreground="White">
Lancement de la partie
                                    </TextBlock>
                                </ControlTemplate>
                            </Button.Template>

                        </Button>
                    </Viewbox>
                </Border>

            </Grid>

        </Grid>
    </Border>
</Page>
