<Page x:Class="Interfaces.Pages.ChoixModeJeu"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Interfaces.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="210" d:DesignWidth="414"
      Title="ChoixModeJeu">
    
    <Border Background="#8176A8" CornerRadius="10">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="11*"/>
                <RowDefinition Height="20*"/>
                <RowDefinition Height="47*"/>
                <RowDefinition Height="7*"/>
                <RowDefinition Height="32*"/>
                <RowDefinition Height="7*"/>
                <RowDefinition Height="31*"/>
                <RowDefinition Height="13*"/>
                <RowDefinition Height="35*"/>
                <RowDefinition Height="7*"/>
            </Grid.RowDefinitions>
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="188*"/>
                <ColumnDefinition Width="19*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="brdCroix" Grid.Column="1" Grid.Row="0" Grid.RowSpan="2" CornerRadius="10" Background="#20114A" BorderBrush="White" BorderThickness="0" Margin="5,5,5,5">
                <Viewbox>
                    <Button x:Name="btnCroix" Background="Transparent" OverridesDefaultStyle="True" Click="btnCroix_Click" >
                        <Button.Template>
                            <ControlTemplate>
                                <TextBlock Foreground="{DynamicResource ButtonTextColor}" FontFamily="Arial Rounded MT Bold">X</TextBlock>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Viewbox>
            </Border>

            <Grid Grid.ColumnSpan="2" Grid.RowSpan="2" Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="87*"/>
                    <ColumnDefinition Width="214*"/>
                    <ColumnDefinition Width="87*"/>
                </Grid.ColumnDefinitions>

                <Viewbox Grid.Column="1">
                    <TextBlock Foreground="{DynamicResource ButtonTextColor}" TextAlignment="Center">
                        Quel mode de jeu
                        <LineBreak />
                        souhaitez-vous faire ?
                    </TextBlock>
                </Viewbox>
            </Grid>

            <Grid Grid.Row="4" Grid.ColumnSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="98*"/>
                    <ColumnDefinition Width="102*"/>
                    <ColumnDefinition Width="16*"/>
                    <ColumnDefinition Width="102*"/>
                    <ColumnDefinition Width="98*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="brdClass" Grid.Column="1" CornerRadius="10" Background="#20114A" BorderBrush="White" BorderThickness="2">
                    <Viewbox>
                        <Button x:Name="btnClassique" Background="Transparent" OverridesDefaultStyle="True" Click="btnClassique_Click">
                            <Button.Template>
                                <ControlTemplate>
                                    <TextBlock Foreground="{DynamicResource ButtonTextColor}">Classique</TextBlock>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Viewbox>
                </Border>

                <Border x:Name="brdChall" Grid.Column="3" CornerRadius="10" Background="#20114A" BorderBrush="White" BorderThickness="0">
                    <Viewbox>
                        <Button x:Name="btnChallenge" Background="Transparent" OverridesDefaultStyle="True" BorderThickness="0" Click="btnChallenge_Button_Click">
                            <Button.Template>
                                <ControlTemplate>
                                    <TextBlock Foreground="{DynamicResource ButtonTextColor}">Challenge</TextBlock>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Viewbox>
                </Border>
            </Grid>

            <Grid Grid.Row="6" Grid.ColumnSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="121*"/>
                    <ColumnDefinition Width="78*"/>
                    <ColumnDefinition Width="19*"/>
                    <ColumnDefinition Width="78*"/>
                    <ColumnDefinition Width="118*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="brd3V" Grid.Column="1" CornerRadius="10" Background="#605786" BorderBrush="White" BorderThickness="0">
                    <Viewbox>
                        <Button x:Name="btn3V" Background="Transparent" OverridesDefaultStyle="True" BorderThickness="0" IsEnabled="False" Click="btn3V_Click">
                            <Button.Template>
                                <ControlTemplate>
                                    <TextBlock Foreground="{DynamicResource ButtonTextColor}">3 victoires</TextBlock>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Viewbox>
                </Border>

                <Border x:Name="brd5V" Grid.Column="3" CornerRadius="10" Background="#605786" BorderBrush="White" BorderThickness="0">
                    <Viewbox>
                        <Button x:Name="btn5V" Background="Transparent" OverridesDefaultStyle="True" BorderThickness="0" IsEnabled="False" Click="btn5V_Click">
                            <Button.Template>
                                <ControlTemplate>
                                    <TextBlock Foreground="{DynamicResource ButtonTextColor}">5 victoires</TextBlock>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Viewbox>
                </Border>
            </Grid>

            <Grid Grid.Row="8" Grid.ColumnSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="64*"/>
                    <ColumnDefinition Width="77*"/>
                    <ColumnDefinition Width="64*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="1" CornerRadius="10" Background="#20114A">
                    <Viewbox>
                        <Button Background="Transparent" OverridesDefaultStyle="True" BorderThickness="0" Click="Btn_LancementPartie">
                            <Button.Template>
                                <ControlTemplate>
                                    <TextBlock Foreground="{DynamicResource ButtonTextColor}">Lancement de la partie</TextBlock>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Viewbox>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Page>