<Page x:Class="Interfaces.Pages.HistoriquePartie"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Interfaces.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ScoreBoard"
      Background="#20114a">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="19*"/>
            <RowDefinition Height="35*"/>
            <RowDefinition Height="377*"/>
            <RowDefinition Height="19*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="62*"/>
            <ColumnDefinition Width="143*"/>
            <ColumnDefinition Width="391*"/>
            <ColumnDefinition Width="205*"/>
        </Grid.ColumnDefinitions>

        <!--Bouton retour en arrière-->

        <Border x:Name="ExitHistorique" Background="#8176a8" CornerRadius="10" Grid.Row="0" Grid.RowSpan="2">
            <Button x:Name="BtnRetour" Click="OnLeavePage" Background="Transparent">
                <TextBlock Text="X" FontSize="30" Foreground="#ffffff" FontFamily="Arial Rounded MT Bold"></TextBlock>
            </Button>
        </Border>

        <!--Affichage de l'historique des parties-->

        <Border CornerRadius="15"  Grid.Row="1" Grid.RowSpan="2" Grid.Column="2" Background="#004aad"></Border>

        <Grid Grid.Column="2" Grid.RowSpan="2" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="19*"/>
                <RowDefinition Height="35*"/>
                <RowDefinition Height="10*"/>
                <RowDefinition Height="35*"/>
                <RowDefinition Height="10*"/>
                <RowDefinition Height="322*"/>
                <RowDefinition Height="19*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="27*"/>
                <ColumnDefinition Width="26*"/>
                <ColumnDefinition Width="353*"/>
                <ColumnDefinition Width="26*"/>
                <ColumnDefinition Width="27*"/>
            </Grid.ColumnDefinitions>

            <Border CornerRadius="12"  Grid.Row="1" Grid.Column="1" Background="#20114a" Grid.ColumnSpan="2" Margin="22,0,0,0">
                <TextBlock Text="Leaderboard" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30" Foreground="#ffffff" FontFamily="Agency FB"/>
            </Border>

            <Border Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" Background="Transparent">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" CornerRadius="8" BorderBrush="#ffffff" BorderThickness="2" Background="Transparent" HorizontalAlignment="Left">
                        <TextBlock Text="    TOP 10    " Foreground="White" HorizontalAlignment="Left" FontFamily="Agency FB" VerticalAlignment="Center"/>
                    </Border>

                    <Border Grid.Column="1" CornerRadius="8" BorderBrush="#ffffff" BorderThickness="2" Background="Transparent" HorizontalAlignment="Right">
                        <TextBlock Text="   Nombre de victoire   " Foreground="White" VerticalAlignment="Center" FontFamily="Agency FB" HorizontalAlignment="Right"/>
                    </Border>

                </Grid>
            </Border>
            <Border CornerRadius="12" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" VerticalAlignment="Center" HorizontalAlignment="Right">

            </Border>

            <ScrollViewer Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="4" Margin="0,3,23,11" FontFamily="Agency FB">

                <!--Améliorer le visuel du ScrollViewer-->
                <ScrollViewer.Template>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ScrollContentPresenter Grid.Column="0"/>

                            <ScrollBar x:Name="PART_VerticalScrollBar" 
                           Grid.Column="1"
                           Value="{TemplateBinding VerticalOffset}" 
                           Maximum="{TemplateBinding ScrollableHeight}" 
                           ViewportSize="{TemplateBinding ViewportHeight}" 
                           Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                           Width="10" 
                           Background="Transparent"
                           Margin="5,0,0,0">
                                <ScrollBar.Template>
                                    <ControlTemplate TargetType="ScrollBar">
                                        <Track x:Name="PART_Track" IsDirectionReversed="true">
                                            <Track.DecreaseRepeatButton>
                                                <RepeatButton Command="ScrollBar.PageUpCommand" Background="Transparent" BorderThickness="0"/>
                                            </Track.DecreaseRepeatButton>
                                            <Track.IncreaseRepeatButton>
                                                <RepeatButton Command="ScrollBar.PageDownCommand" Background="Transparent" BorderThickness="0"/>
                                            </Track.IncreaseRepeatButton>
                                            <Track.Thumb>
                                                <Thumb>
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border Background="#FFFFFF" CornerRadius="4" Width="6" Height="Auto"/>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>
                                        </Track>
                                    </ControlTemplate>
                                </ScrollBar.Template>
                            </ScrollBar>
                        </Grid>
                    </ControlTemplate>
                </ScrollViewer.Template>
                <StackPanel>

                    <!--Début de l'affichage des parties-->

                    <Border CornerRadius="12" Margin="0,0,10,10" Background="#20114a" Height="40">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="53*"/>
                                <ColumnDefinition Width="75*"/>
                                <ColumnDefinition Width="123*"/>
                                <ColumnDefinition Width="62*"/>
                            </Grid.ColumnDefinitions>

                            <!--Placement-->
                            <TextBlock Text="#1" FontSize="30" HorizontalAlignment="Center" Foreground="#ffffff" VerticalAlignment="Center"/>
                            <!--Pseudonyme des joueurs-->
                            <TextBlock Grid.Column="1" Text="UneTable" Foreground="#ffffff" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15" />
                            <!--Nombre de victoires-->
                            <TextBlock Text="7" FontSize="20" Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#ffffff"/>
                        </Grid>
                    </Border>

                    <Border CornerRadius="12" Margin="0,0,10,10" Background="#20114a" Height="40">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="53*"/>
                                <ColumnDefinition Width="75*"/>
                                <ColumnDefinition Width="123*"/>
                                <ColumnDefinition Width="62*"/>
                            </Grid.ColumnDefinitions>

                            <!--Placement-->
                            <TextBlock Text="#2" FontSize="30" HorizontalAlignment="Center" Foreground="#ffffff" VerticalAlignment="Center"/>
                            <!--Pseudonyme des joueurs-->
                            <TextBlock Grid.Column="1" Text="Jiao" Foreground="#ffffff" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15"/>
                            <!--Nombre de victoires-->
                            <TextBlock Text="5" FontSize="20" Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#ffffff"/>
                        </Grid>
                    </Border>

                    <Border CornerRadius="12" Margin="0,0,10,10" Background="#20114a" Height="40">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="53*"/>
                                <ColumnDefinition Width="75*"/>
                                <ColumnDefinition Width="123*"/>
                                <ColumnDefinition Width="62*"/>
                            </Grid.ColumnDefinitions>

                            <!--Placement-->
                            <TextBlock Text="#3" FontSize="30" HorizontalAlignment="Center" Foreground="#ffffff" VerticalAlignment="Center"/>
                            <!--Pseudonyme des joueurs-->
                            <TextBlock Grid.Column="1" Text="Bernard" Foreground="#ffffff" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15"/>
                            <!--Nombre de victoires-->
                            <TextBlock Text="4" FontSize="20" Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#ffffff"/>
                        </Grid>
                    </Border>

                    <Border CornerRadius="12" Margin="0,0,10,10" Background="#20114a" Height="40">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="53*"/>
                                <ColumnDefinition Width="75*"/>
                                <ColumnDefinition Width="123*"/>
                                <ColumnDefinition Width="62*"/>
                            </Grid.ColumnDefinitions>

                            <!--Placement-->
                            <TextBlock Text="#4" FontSize="30" HorizontalAlignment="Center" Foreground="#ffffff" VerticalAlignment="Center"/>
                            <!--Pseudonyme des joueurs-->
                            <TextBlock Grid.Column="1" Text="Polo" Foreground="#ffffff" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15"/>
                            <!--Nombre de victoires-->
                            <TextBlock Text="3" FontSize="20" Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#ffffff"/>
                        </Grid>
                    </Border>

                    <Border CornerRadius="12" Margin="0,0,10,10" Background="#20114a" Height="40">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="53*"/>
                                <ColumnDefinition Width="75*"/>
                                <ColumnDefinition Width="123*"/>
                                <ColumnDefinition Width="62*"/>
                            </Grid.ColumnDefinitions>

                            <!--Placement-->
                            <TextBlock Text="#5" FontSize="30" HorizontalAlignment="Center" Foreground="#ffffff" VerticalAlignment="Center"/>
                            <!--Pseudonyme des joueurs-->
                            <TextBlock Grid.Column="1" Text="Maé" Foreground="#ffffff" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15"/>
                            <!--Nombre de victoires-->
                            <TextBlock Text="3" FontSize="20" Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#ffffff"/>
                        </Grid>
                    </Border>

                    <Border CornerRadius="12" Margin="0,0,10,10" Background="#20114a" Height="40">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="53*"/>
                                <ColumnDefinition Width="75*"/>
                                <ColumnDefinition Width="123*"/>
                                <ColumnDefinition Width="62*"/>
                            </Grid.ColumnDefinitions>

                            <!--Placement-->
                            <TextBlock Text="#6" FontSize="30" HorizontalAlignment="Center" Foreground="#ffffff" VerticalAlignment="Center"/>
                            <!--Pseudonyme des joueurs-->
                            <TextBlock Grid.Column="1" Text="Clem" Foreground="#ffffff" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15"/>
                            <!--Nombre de victoires-->
                            <TextBlock Text="2" FontSize="20" Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#ffffff"/>
                        </Grid>
                    </Border>

                    <Border CornerRadius="12" Margin="0,0,10,10" Background="#20114a" Height="40">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="53*"/>
                                <ColumnDefinition Width="75*"/>
                                <ColumnDefinition Width="123*"/>
                                <ColumnDefinition Width="62*"/>
                            </Grid.ColumnDefinitions>

                            <!--Placement-->
                            <TextBlock Text="#7" FontSize="30" HorizontalAlignment="Center" Foreground="#ffffff" VerticalAlignment="Center"/>
                            <!--Pseudonyme des joueurs-->
                            <TextBlock Grid.Column="1" Text="Bot" Foreground="#ffffff" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15"/>
                            <!--Nombre de victoires-->
                            <TextBlock Text="1" FontSize="20" Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#ffffff"/>
                        </Grid>
                    </Border>

                    <Border CornerRadius="12" Margin="0,0,10,10" Background="#20114a" Height="40">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="53*"/>
                                <ColumnDefinition Width="75*"/>
                                <ColumnDefinition Width="123*"/>
                                <ColumnDefinition Width="62*"/>
                            </Grid.ColumnDefinitions>

                            <!--Placement-->
                            <TextBlock Text="#8" FontSize="30" HorizontalAlignment="Center" Foreground="#ffffff" VerticalAlignment="Center"/>
                            <!--Pseudonyme des joueurs-->
                            <TextBlock Grid.Column="1" Text="Loïc" Foreground="#ffffff" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15"/>
                            <!--Nombre de victoires-->
                            <TextBlock Text="0" FontSize="20" Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#ffffff"/>
                        </Grid>
                    </Border>

                    <Border CornerRadius="12" Margin="0,0,10,10" Background="#20114a" Height="40">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="53*"/>
                                <ColumnDefinition Width="75*"/>
                                <ColumnDefinition Width="123*"/>
                                <ColumnDefinition Width="62*"/>
                            </Grid.ColumnDefinitions>

                            <!--Placement-->
                            <TextBlock Text="#9" FontSize="30" HorizontalAlignment="Center" Foreground="#ffffff" VerticalAlignment="Center"/>
                            <!--Pseudonyme des joueurs-->
                            <TextBlock Grid.Column="1" Text="Volcan" Foreground="#ffffff" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15"/>
                            <!--Nombre de victoires-->
                            <TextBlock Text="0" FontSize="20" Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#ffffff"/>
                        </Grid>
                    </Border>

                    <Border CornerRadius="12" Margin="0,0,10,10" Background="#20114a" Height="40">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="53*"/>
                                <ColumnDefinition Width="75*"/>
                                <ColumnDefinition Width="123*"/>
                                <ColumnDefinition Width="62*"/>
                            </Grid.ColumnDefinitions>

                            <!--Placement-->
                            <TextBlock Text="#10" FontSize="30" HorizontalAlignment="Center" Foreground="#ffffff" VerticalAlignment="Center"/>
                            <!--Pseudonyme des joueurs-->
                            <TextBlock Grid.Column="1" Text="Lacden" Foreground="#ffffff" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15"/>
                            <!--Nombre de victoires-->
                            <TextBlock Text="0" FontSize="20" Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#ffffff"/>
                        </Grid>
                    </Border>
                    <!--Fin de l'affichage des parties-->
                    

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
