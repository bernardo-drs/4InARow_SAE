<Page x:Class="Interfaces.Pages.ParametresJoueur2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Page.Resources>
        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="Background"                 Value="#5A5480"/>
            <Setter Property="Foreground"                 Value="White"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="FontSize"                    Value="16"/>
            <Setter Property="FontFamily"                 Value="Segoe UI"/>
            <Setter Property="Padding"                    Value="16,0"/>
            <Setter Property="Height"                     Value="46"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
            <Setter Property="AcceptsReturn"              Value="False"/>
            <Setter Property="TextWrapping"               Value="NoWrap"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                    CornerRadius="20" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <TextBlock x:Name="Placeholder"
                               Text="{TemplateBinding Tag}"
                               Foreground="#AAAACC"
                               FontStyle="Italic"
                               FontSize="{TemplateBinding FontSize}"
                               FontFamily="{TemplateBinding FontFamily}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"
                               Visibility="Collapsed"/>
                                <ScrollViewer x:Name="PART_ContentHost"
                                  VerticalAlignment="Center"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Hidden"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Text" Value=""/>
                                    <Condition Property="IsFocused" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ColorButton" TargetType="Button">
            <Setter Property="Width"           Value="42"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Margin"          Value="4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Tag"              Value="unselected"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="Ring" Width="42" Height="42"
                                     Fill="Transparent" StrokeThickness="0"/>
                            <Ellipse Width="34" Height="34"
                                     Fill="{TemplateBinding Background}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Ring" Property="Stroke" Value="White"/>
                                <Setter TargetName="Ring" Property="StrokeThickness" Value="2"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="selected">
                                <Setter TargetName="Ring" Property="Stroke" Value="White"/>
                                <Setter TargetName="Ring" Property="StrokeThickness" Value="3"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Viewbox Stretch="Uniform">
        <Grid Width="420" Margin="20,15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="22"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="22"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="25"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" 
                       Text="Informations du joueur 2"
                       FontFamily="Agency FB"
                       Foreground="White" FontSize="{DynamicResource FontSize22}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,15"/>

            <TextBlock Grid.Row="1"
                       Text="Nom"
                       FontFamily="Agency FB"
                       Foreground="White" FontSize="{DynamicResource FontSize17}"
                       HorizontalAlignment="Left" Margin="10,0,0,4"/>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtNomJ2" x:FieldModifier="public"
                         Text="" Tag="Entrez un nom..."
                         Style="{StaticResource RoundedTextBox}"/>
                <TextBlock x:Name="IconErrNomJ2" x:FieldModifier="public"
                           Grid.Column="1"
                           Text="⚠" Foreground="#E53935"
                           FontSize="{DynamicResource FontSize17}" VerticalAlignment="Center"
                           Margin="8,0,0,0" Visibility="Hidden"/>
            </Grid>

            <TextBlock x:Name="ErrNomJ2" x:FieldModifier="public"
                       Grid.Row="3"
                       Foreground="#E53935" FontSize="{DynamicResource FontSize12}"
                       FontFamily="Segoe UI" FontStyle="Italic"
                       HorizontalAlignment="Left" Margin="12,2,0,0"
                       VerticalAlignment="Top"
                       Visibility="Hidden"/>
            <TextBlock Grid.Row="4"
                       Text="Nationalité"
                       FontFamily="Agency FB"
                       Foreground="White" FontSize="{DynamicResource FontSize17}"
                       HorizontalAlignment="Left" Margin="10,0,0,4"/>

            <Grid Grid.Row="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtNatJ2" x:FieldModifier="public"
                         Text="" Tag="Entrez une nationalité..."
                         Style="{StaticResource RoundedTextBox}"/>
                <TextBlock x:Name="IconErrNatJ2" x:FieldModifier="public"
                           Grid.Column="1"
                           Text="⚠" Foreground="#E53935"
                           FontSize="{DynamicResource FontSize17}" VerticalAlignment="Center"
                           Margin="8,0,0,0" Visibility="Hidden"/>
            </Grid>

            <TextBlock x:Name="ErrNatJ2" x:FieldModifier="public"
                       Grid.Row="6"
                       Foreground="#E53935" FontSize="{DynamicResource FontSize12}"
                       FontFamily="Segoe UI" FontStyle="Italic"
                       HorizontalAlignment="Left" Margin="12,2,0,0"
                       VerticalAlignment="Top"
                       Visibility="Hidden"/>

            <TextBlock Grid.Row="7"
                       Text="Couleur des jetons"
                       FontFamily="Agency FB"
                       Foreground="White" FontSize="{DynamicResource FontSize17}"
                       HorizontalAlignment="Left" Margin="10,0,0,8"/>

            <Grid Grid.Row="8" HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#4A4470" CornerRadius="14" Padding="10,8">
                    <UniformGrid Columns="4" Rows="2">
                        <Button Style="{StaticResource ColorButton}" Background="#ff3131" Click="ColorButton_Click"/>
                        <Button Style="{StaticResource ColorButton}" Background="#ff66c4" Click="ColorButton_Click"/>
                        <Button Style="{StaticResource ColorButton}" Background="#000000" Click="ColorButton_Click"/>
                        <Button Style="{StaticResource ColorButton}" Background="#5e17eb" Click="ColorButton_Click"/>
                        <Button Style="{StaticResource ColorButton}" Background="#ffde59" Click="ColorButton_Click"/>
                        <Button Style="{StaticResource ColorButton}" Background="#7ed957" Click="ColorButton_Click"/>
                        <Button Style="{StaticResource ColorButton}" Background="#ffffff" Click="ColorButton_Click"/>
                        <Button Style="{StaticResource ColorButton}" Background="#ff751f" Click="ColorButton_Click"/>
                    </UniformGrid>
                </Border>
                <TextBlock x:Name="IconErrCoulJ2" x:FieldModifier="public"
                           Grid.Column="1"
                           Text="⚠" Foreground="#E53935"
                           FontSize="{DynamicResource FontSize17}" VerticalAlignment="Center"
                           Margin="8,0,0,0" Visibility="Hidden"/>
            </Grid>

            <TextBlock x:Name="ErrCoulJ2" x:FieldModifier="public"
                       Grid.Row="9"
                       Foreground="#E53935" FontSize="{DynamicResource FontSize12}"
                       FontFamily="Segoe UI" FontStyle="Italic"
                       HorizontalAlignment="Center" Margin="0,4,0,0"
                       Visibility="Hidden"/>
        </Grid>
    </Viewbox>
</Page>