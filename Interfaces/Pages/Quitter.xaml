<Page x:Class="Interfaces.Pages.Quitter"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Interfaces.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="200" d:DesignWidth="522"
      Title="Quitter" >

    <Border Background="#8176A8" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="18*"/>
                <RowDefinition Height="44*"/>
                <RowDefinition Height="19*"/>
                <RowDefinition Height="54*"/>
                <RowDefinition Height="19*"/>
                <RowDefinition Height="37*"/>
                <RowDefinition Height="8*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150*"/>
                    <ColumnDefinition Width="217*"/>
                    <ColumnDefinition Width="150*"/>
                </Grid.ColumnDefinitions>
                <Border Background ="#201A43" Grid.Column="1" CornerRadius="5">
                    <Viewbox Margin="5">
                        <TextBlock Foreground="#FAFAFA" VerticalAlignment="Center" HorizontalAlignment="Center">
                            Quitter
                        </TextBlock>
                    </Viewbox>
                </Border>
            </Grid>
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40*"/>
                    <ColumnDefinition Width="277*"/>
                    <ColumnDefinition Width="40*"/>
                </Grid.ColumnDefinitions>
                <Viewbox Margin="5" Grid.Column="1">
                    <TextBlock Foreground="#FAFAFA" VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap">
                            Êtes-vous sur de vouloir quitter le jeu ?
                    </TextBlock>
                </Viewbox>
            </Grid>
            <Grid Grid.Row="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40*"/>
                    <ColumnDefinition Width="80*"/>
                    <ColumnDefinition Width="50*"/>
                    <ColumnDefinition Width="80*"/>
                    <ColumnDefinition Width="40*"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="OuiQuitterButtonHolder" Background="#201A43" Tag="#201A43" CornerRadius="5" Grid.Column="1" MouseEnter="OnMouseEnterButton" MouseLeave="OnMouseLeaveButton">
                    <Button x:Name="OuiQuitter" BorderThickness="0" OverridesDefaultStyle="True"  Padding="10"  Background="Transparent" Tag="Quitter" Click="OuiQuitterButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Viewbox Margin="8">
                                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20" Foreground="#FAFAFA" FontStretch="Expanded">
                                    Oui
                                    </TextBlock>
                                </Viewbox>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Border>
                <Border x:Name="NonQuitterButtonHolder" Background="#201A43" Tag="#201A43" CornerRadius="5" Grid.Column="3" MouseEnter="OnMouseEnterButton" MouseLeave="OnMouseLeaveButton">
                    <Button x:Name="NonQuitter" BorderThickness="0" OverridesDefaultStyle="True"  Padding="10"  Background="Transparent" Tag="Quitter" Click="NonQuitterButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Viewbox Margin="8">
                                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20" Foreground="#FAFAFA" FontStretch="Expanded">
                                    Non
                                    </TextBlock>
                                </Viewbox>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Page>
