<Page x:Class="Interfaces.Pages.Parametres"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Interfaces.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="520" d:DesignWidth="900"
      Title="Parametres"
      Background="{DynamicResource BackgroundColor}">

    <Page.Resources>

        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="Background"                 Value="#5A5480"/>
            <Setter Property="Foreground"                 Value="White"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="FontSize"                   Value="16"/>
            <Setter Property="FontFamily"                 Value="Segoe UI"/>
            <Setter Property="Padding"                    Value="10,6"/>
            <Setter Property="Height"                     Value="38"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
            <Setter Property="AcceptsReturn"              Value="False"/>
            <Setter Property="TextWrapping"               Value="NoWrap"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="20" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <TextBlock x:Name="Placeholder"
                                           Text="{TemplateBinding Tag}"
                                           Foreground="#AAAACC"
                                           FontStyle="Italic"
                                           FontSize="{TemplateBinding FontSize}"
                                           FontFamily="{TemplateBinding FontFamily}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed"/>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              VerticalAlignment="Center"
                                              HorizontalScrollBarVisibility="Hidden"
                                              VerticalScrollBarVisibility="Hidden"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Text" Value=""/>
                                    <Condition Property="IsFocused" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ColorButton" TargetType="Button">
            <Setter Property="Width"           Value="42"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Margin"          Value="4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Tag"             Value="unselected"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="Ring" Width="42" Height="42"
                                     Fill="Transparent" StrokeThickness="0"/>
                            <Ellipse Width="34" Height="34"
                                     Fill="{TemplateBinding Background}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Ring" Property="Stroke" Value="White"/>
                                <Setter TargetName="Ring" Property="StrokeThickness" Value="2"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="selected">
                                <Setter TargetName="Ring" Property="Stroke" Value="White"/>
                                <Setter TargetName="Ring" Property="StrokeThickness" Value="3"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SaveButton" TargetType="Button">
            <Setter Property="Background"      Value="#5A5480"/>
            <Setter Property="Foreground"      Value="Black"/>
            <Setter Property="FontSize"        Value="20"/>
            <Setter Property="FontFamily"      Value="Baskerville Old Face"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="30,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="20" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#6B659A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4A4470"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Width"           Value="36"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Background"      Value="#5A5480"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Width="36" Height="36">
                            <TextBlock Text="✕" Foreground="White"
                                       FontSize="{DynamicResource FontSize17}" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C0392B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabButton" TargetType="Button">
            <Setter Property="Background"      Value="#4A4470"/>
            <Setter Property="Foreground"      Value="#BBBBCC"/>
            <Setter Property="FontFamily"      Value="Baskerville Old Face"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="Padding"         Value="16,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="4,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#6B659A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabButtonActive" TargetType="Button"
               BasedOn="{StaticResource TabButton}">
            <Setter Property="Background" Value="#7B75B0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

    </Page.Resources>

    <Viewbox Stretch="Uniform">
        <Grid Width="900" Height="520">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── Titre ── -->
            <Grid Grid.Row="0" Margin="16,10,16,0" MinHeight="50">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="36"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="36"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="1"
                           Text="Paramètres"
                           Foreground="White" FontSize="{DynamicResource FontSize35}"
                           FontFamily="Georgia"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="2"
                        Style="{StaticResource CloseButton}"
                        VerticalAlignment="Center"
                        Click="BtnClose_Click"/>
            </Grid>

            <!-- ── Corps ── -->
            <Grid Grid.Row="1" Margin="8,16,8,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Séparateur vertical -->
                <Rectangle Grid.Column="1" Grid.Row="0" Grid.RowSpan="12"
                           Fill="White" VerticalAlignment="Stretch" Margin="0,4,0,4"/>

                <!-- ══ Row 0 : tabs ══ -->
                <StackPanel Grid.Column="2" Grid.Row="0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,14">
                    <Button x:Name="BtnTab2J" Content="2 Joueurs"
                            Style="{StaticResource TabButton}"
                            Click="BtnTab2J_Click"/>
                    <Button x:Name="BtnTabIA" Content="Contre l'IA"
                            Style="{StaticResource TabButton}"
                            Click="BtnTabIA_Click"/>
                </StackPanel>

                <!-- ══ Row 1 : titre J1 ══ -->
                <TextBlock Grid.Column="0" Grid.Row="1"
                           Text="Informations du joueur 1"
                           FontFamily="Baskerville Old Face"
                           Foreground="White" FontSize="{DynamicResource FontSize15}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- ══ Row 2 : label Nom J1 ══ -->
                <TextBlock Grid.Column="0" Grid.Row="2"
                           Text="Nom"
                           FontFamily="Baskerville Old Face"
                           Foreground="White" FontSize="{DynamicResource FontSize17}"
                           HorizontalAlignment="Left" Margin="12,0,0,6"/>

                <!-- ══ Row 3 : TextBox Nom J1 + icône ══ -->
                <Grid Grid.Column="0" Grid.Row="3" Margin="12,0,12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtNomJ1"
                                 Text="" Tag="Entrez un nom..."
                                 Style="{StaticResource RoundedTextBox}"
                                 Width="400" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="IconErrNomJ1"
                               Grid.Column="1"
                               Text="ⓘ" Foreground="#E53935"
                               FontSize="{DynamicResource FontSize17}" VerticalAlignment="Center"
                               Margin="6,0,0,0" Visibility="Collapsed"/>
                </Grid>

                <!-- ══ Row 4 : erreur Nom J1 ══ -->
                <TextBlock x:Name="ErrNomJ1"
                           Grid.Column="0" Grid.Row="4"
                           Foreground="#E53935" FontSize="{DynamicResource FontSize12}"
                           FontFamily="Segoe UI" FontStyle="Italic"
                           HorizontalAlignment="Left" Margin="14,2,0,4"
                           Visibility="Collapsed"/>

                <!-- ══ Row 5 : label Nationalité J1 ══ -->
                <TextBlock Grid.Column="0" Grid.Row="5"
                           Text="Nationalité"
                           FontFamily="Baskerville Old Face"
                           Foreground="White" FontSize="{DynamicResource FontSize17}"
                           HorizontalAlignment="Left" Margin="12,0,0,6"/>

                <!-- ══ Row 6 : TextBox Nationalité J1 + icône ══ -->
                <Grid Grid.Column="0" Grid.Row="6" Margin="12,0,12,0">
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
    </Grid.ColumnDefinitions>
    
    <TextBox x:Name="TxtNatJ1"
             Text="" Tag="Entrez une nationalité..."
             Style="{StaticResource RoundedTextBox}"
             HorizontalAlignment="Stretch"/>
             
    <TextBlock x:Name="IconErrNatJ1"
               Grid.Column="1"
               Text="ⓘ" Foreground="#E53935"
               FontSize="{DynamicResource FontSize17}" VerticalAlignment="Center"
               Margin="6,0,0,0" Visibility="Collapsed"/>
</Grid>

                <!-- ══ Row 7 : erreur Nationalité J1 ══ -->
                <TextBlock x:Name="ErrNatJ1"
                           Grid.Column="0" Grid.Row="7"
                           Foreground="#E53935" FontSize="{DynamicResource FontSize12}"
                           FontFamily="Segoe UI" FontStyle="Italic"
                           HorizontalAlignment="Left" Margin="14,2,0,4"
                           Visibility="Collapsed"/>

                <!-- ══ Row 8 : label Couleur J1 ══ -->
                <TextBlock Grid.Column="0" Grid.Row="8"
                           Text="Couleur des jetons"
                           FontFamily="Baskerville Old Face"
                           Foreground="White" FontSize="{DynamicResource FontSize17}"
                           HorizontalAlignment="Left" Margin="12,0,0,10"/>

                <!-- ══ Row 9 : palette J1 + icône ══ -->
                <Grid Grid.Column="0" Grid.Row="9" HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#4A4470" CornerRadius="14" Padding="10,8">
                        <UniformGrid Columns="4" Rows="2">
                            <Button Style="{StaticResource ColorButton}" Background="#E53935" Tag="unselected" Click="ColorButton_Click"/>
                            <Button Style="{StaticResource ColorButton}" Background="#E91E8C" Tag="unselected" Click="ColorButton_Click"/>
                            <Button Style="{StaticResource ColorButton}" Background="#1A1A1A" Tag="unselected" Click="ColorButton_Click"/>
                            <Button Style="{StaticResource ColorButton}" Background="#7B1FA2" Tag="unselected" Click="ColorButton_Click"/>
                            <Button Style="{StaticResource ColorButton}" Background="#FDD835" Tag="unselected" Click="ColorButton_Click"/>
                            <Button Style="{StaticResource ColorButton}" Background="#43A047" Tag="unselected" Click="ColorButton_Click"/>
                            <Button Style="{StaticResource ColorButton}" Background="#EEEEEE" Tag="unselected" Click="ColorButton_Click"/>
                            <Button Style="{StaticResource ColorButton}" Background="#FF6F00" Tag="unselected" Click="ColorButton_Click"/>
                        </UniformGrid>
                    </Border>
                    <TextBlock x:Name="IconErrCoulJ1"
                               Grid.Column="1"
                               Text="ⓘ" Foreground="#E53935"
                               FontSize="{DynamicResource FontSize17}" VerticalAlignment="Center"
                               Margin="8,0,0,0" Visibility="Collapsed"/>
                </Grid>

                <!-- ══ Row 10 : erreur Couleur J1 ══ -->
                <TextBlock x:Name="ErrCoulJ1"
                           Grid.Column="0" Grid.Row="10"
                           Foreground="#E53935" FontSize="{DynamicResource FontSize12}"
                           FontFamily="Segoe UI" FontStyle="Italic"
                           HorizontalAlignment="Center" Margin="0,4,0,0"
                           Visibility="Collapsed"/>

                <!-- ══ Frame droite : J2 ou IA ══ -->
                <Frame x:Name="RightFrame"
                       Grid.Column="2" Grid.Row="1" Grid.RowSpan="11"
                       NavigationUIVisibility="Hidden"
                       Background="Transparent"
                       VerticalAlignment="Top"
                       Margin="8,0,8,0"/>
            </Grid>

            <!-- ── Bouton bas ── -->
            <Grid Grid.Row="2" Margin="0,0,0,16">
                <Button Content="Enregistrer les données"
                        Style="{StaticResource SaveButton}"
                        HorizontalAlignment="Center"
                        Tag="Parametres"
                        Click="BtnSave_Click"/>
            </Grid>
        </Grid>
    </Viewbox>

</Page>