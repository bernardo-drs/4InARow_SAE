<Page x:Class="Interfaces.Pages.Accueil"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Interfaces.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="560" d:DesignWidth="996"
      Title="Accueil" Background="#20114A" FontFamily="Agency FB">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250*"/>
            <ColumnDefinition Width="300*"/>
            <ColumnDefinition Width="250*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="36*"/>
            <RowDefinition Height="85*"/>
            <RowDefinition Height="34*"/>
            <RowDefinition Height="252*"/>
            <RowDefinition Height="43*"/>
        </Grid.RowDefinitions>
        <Viewbox Grid.ColumnSpan="3" Grid.Row="1" >
            <TextBlock x:Name="GameTitle" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#FAFAFA">
    Puissance 4
            </TextBlock>
        </Viewbox>

        <Grid Grid.Row="3" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="25*"/>
                <RowDefinition Height="7*"/>
                <RowDefinition Height="25*"/>
                <RowDefinition Height="7*"/>
                <RowDefinition Height="25*"/>
                <RowDefinition Height="7*"/>
                <RowDefinition Height="25*"/>
                <RowDefinition Height="7*"/>
                <RowDefinition Height="25*"/>
            </Grid.RowDefinitions>


            <!--Bouton Jouer-->

            <Border x:Name="PlayButtonHolder"
Background="#FAFAFA"
CornerRadius="10"
Tag="#FAFAFA"
Grid.Row="0"
MouseEnter="OnMouseEnterButton"
MouseLeave="OnMouseLeaveButton">

                <Button x:Name="PlayButton"
    BorderThickness="0"
    OverridesDefaultStyle="True"
    Background="Transparent"
    Tag="Game"
    Click="OnModeButtonClick"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    Padding="0">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">

                            <Grid Background="Transparent">

                                <Viewbox Margin="8" Stretch="Uniform">

                                    <TextBlock Text="Jouer"
                           FontSize="20"
                           Foreground="Black"
                           FontStretch="Expanded"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                                </Viewbox>

                            </Grid>

                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Border>

            <!--Bouton Options-->

            <Border x:Name="OptionsButtonHolder"
Background="#d3cdff"
CornerRadius="10"
Tag="#d3cdff"
Grid.Row="2"
MouseEnter="OnMouseEnterButton"
MouseLeave="OnMouseLeaveButton">

                <Button x:Name="OptionsButton"
    BorderThickness="0"
    OverridesDefaultStyle="True"
    Background="Transparent"
    Tag="Options"
    Click="OnModeButtonClick"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    Padding="0">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">

                            <Grid Background="Transparent">

                                <Viewbox Margin="8" Stretch="Uniform">

                                    <TextBlock Text="Options"
                           FontSize="20"
                           Foreground="Black"
                           FontStretch="Expanded"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                                </Viewbox>

                            </Grid>

                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Border>
            <!--Bouton Historique-->

            <Border x:Name="HistoriqueButtonHolder"
Background="#a497ff"
CornerRadius="10"
Tag="#a497ff"
Grid.Row="4"
MouseEnter="OnMouseEnterButton"
MouseLeave="OnMouseLeaveButton">

                <Button x:Name="HistoriqueButton"
    BorderThickness="0"
    OverridesDefaultStyle="True"
    Background="Transparent"
    Tag="Historique"
    Click="OnModeButtonClick"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    Padding="0">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">

                            <Grid Background="Transparent">

                                <Viewbox Margin="8" Stretch="Uniform">

                                    <TextBlock Text="Historique"
                           FontSize="20"
                           Foreground="Black"
                           FontStretch="Expanded"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                                </Viewbox>

                            </Grid>

                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Border>



            <!--Bouton Leaderboard-->

            <Border x:Name="LeaderboardButtonHolder"
        Background="#8573ff"
        CornerRadius="10"
        Tag="#8573ff"
        Grid.Row="6"
        MouseEnter="OnMouseEnterButton"
        MouseLeave="OnMouseLeaveButton">

            <Button x:Name="LeaderboardButton"
            BorderThickness="0"
            OverridesDefaultStyle="True"
            Background="Transparent"
            Tag="Leaderboard"
            Click="OnModeButtonClick"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Padding="0">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">

                            <Grid Background="Transparent">

                                <Viewbox Margin="8" Stretch="Uniform">

                                    <TextBlock Text="Leaderboard"
                                   FontSize="20"
                                   Foreground="Black"
                                   FontStretch="Expanded"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                                </Viewbox>

                            </Grid>

                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Border>


            <!--Bouton Quitter-->

            <Border x:Name="QuitterButtonHolder"
        Background="#5170FF"
        CornerRadius="10"
        Tag="#5170FF"
        Grid.Row="8"
        MouseEnter="OnMouseEnterButton"
        MouseLeave="OnMouseLeaveButton">

                <Button x:Name="QuitterButton"
            BorderThickness="0"
            OverridesDefaultStyle="True"
            Background="Transparent"
            Tag="Quitter"
            Click="QuitterButton_Click"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Padding="0">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">

                            <Grid Background="Transparent">

                                <Viewbox Margin="8" Stretch="Uniform">

                                    <TextBlock Text="Quitter"
                                   FontSize="20"
                                   Foreground="Black"
                                   FontStretch="Expanded"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                                </Viewbox>

                            </Grid>

                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Border>
        </Grid>
    </Grid>
</Page>
