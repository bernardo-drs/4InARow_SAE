<Page x:Class="Interfaces.Pages.ParametreJeu"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Interfaces.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ParametreJeu" Background="{DynamicResource BackgroundColor}" FontFamily="Agency FB">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="98*"/>
            <RowDefinition Height="219*"/>
            <RowDefinition Height="98*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="106*"/>
            <ColumnDefinition Width="185*"/>
            <ColumnDefinition Width="106*"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.ColumnSpan="3" Grid.RowSpan="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="18*"/>
                <RowDefinition Height="25*"/>
                <RowDefinition Height="24*"/>
                <RowDefinition Height="9*"/>
                <RowDefinition Height="374*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60*"/>
                <ColumnDefinition Width="175*"/>
                <ColumnDefinition Width="51*"/>
                <ColumnDefinition Width="227*"/>
                <ColumnDefinition Width="51*"/>
                <ColumnDefinition Width="175*"/>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="56*"/>
            </Grid.ColumnDefinitions>

            <Viewbox Grid.Column="3" Grid.Row="1" Grid.RowSpan="2">
                <TextBlock Foreground="White">
                Paramètres
                </TextBlock>
            </Viewbox>

            <Grid Grid.Row="4" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="19*"/>
                    <RowDefinition Height="156*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Viewbox Grid.Column="0" Grid.Row="0">
                    <TextBlock Foreground="White">
                    Taille de la grille
                    </TextBlock>
                </Viewbox>

                <Grid Grid.Column="0" Grid.Row="1" Margin="0,5,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="35*"/>
                        <RowDefinition Height="7*"/>
                        <RowDefinition Height="35*"/>
                        <RowDefinition Height="7*"/>
                        <RowDefinition Height="35*"/>
                        <RowDefinition Height="7*"/>
                        <RowDefinition Height="35*"/>
                        <RowDefinition Height="7*"/>
                        <RowDefinition Height="35*"/>
                        <RowDefinition Height="7*"/>
                        <RowDefinition Height="35*"/>
                        <RowDefinition Height="19*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="21*"/>
                        <ColumnDefinition Width="133*"/>
                        <ColumnDefinition Width="21*"/>
                    </Grid.ColumnDefinitions>

                    <Border BorderBrush="White" Grid.Row="0" Grid.Column="1" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave">

                        <Viewbox>
                            <Button x:Name="btn4" Background="Transparent" OverridesDefaultStyle="False" Click="Button_Click">
                                <Button.Template>
                                    <ControlTemplate>
                                        <TextBlock Foreground="{DynamicResource ButtonTextColor}" Margin="2">
                                        4 x 4
                                        </TextBlock>
                                    </ControlTemplate>
                                </Button.Template>

                            </Button>
                        </Viewbox>


                    </Border>

                    <Border BorderBrush="White" Grid.Row="2" Grid.Column="1" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave">

                        <Viewbox>
                            <Button x:Name="btn5" Background="Transparent" OverridesDefaultStyle="False" Click="Button_Click">
                                <Button.Template>
                                    <ControlTemplate>
                                        <TextBlock Foreground="{DynamicResource ButtonTextColor}" Margin="2">
                        5 x 5
                                        </TextBlock>
                                    </ControlTemplate>
                                </Button.Template>

                            </Button>
                        </Viewbox>


                    </Border>

                    <Border BorderBrush="White" Grid.Row="4" Grid.Column="1" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave">

                        <Viewbox>
                            <Button Background="Transparent" OverridesDefaultStyle="False" Click="Button_Click">
                                <Button.Template>
                                    <ControlTemplate>
                                        <TextBlock Foreground="{DynamicResource ButtonTextColor}" Margin="2">
                        6 x 7
                                        </TextBlock>
                                    </ControlTemplate>
                                </Button.Template>

                            </Button>
                        </Viewbox>


                    </Border>

                    <Border BorderBrush="White" Grid.Row="6" Grid.Column="1" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave">

                        <Viewbox>
                            <Button Background="Transparent" OverridesDefaultStyle="False" Click="Button_Click">
                                <Button.Template>
                                    <ControlTemplate>
                                        <TextBlock Foreground="{DynamicResource ButtonTextColor}" Margin="2">
                        8 x 7
                                        </TextBlock>
                                    </ControlTemplate>
                                </Button.Template>

                            </Button>
                        </Viewbox>


                    </Border>

                    <Border BorderBrush="White" Grid.Row="8" Grid.Column="1" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave">

                        <Viewbox>
                            <Button Background="Transparent" OverridesDefaultStyle="False" Click="Button_Click">
                                <Button.Template>
                                    <ControlTemplate>
                                        <TextBlock Foreground="{DynamicResource ButtonTextColor}" Margin="2">
                        8 x 8
                                        </TextBlock>
                                    </ControlTemplate>
                                </Button.Template>

                            </Button>
                        </Viewbox>


                    </Border>

                    <Border BorderBrush="White" Grid.Row="10" Grid.Column="1" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave">

                        <Viewbox>
                            <Button Background="Transparent" OverridesDefaultStyle="False" Click="Button_Click">
                                <Button.Template>
                                    <ControlTemplate>
                                        <TextBlock Foreground="{DynamicResource ButtonTextColor}" Margin="2">
                        10 x 10
                                        </TextBlock>
                                    </ControlTemplate>
                                </Button.Template>

                            </Button>
                        </Viewbox>


                    </Border>



                </Grid>

            </Grid>

            <Grid Grid.Column="3" Grid.Row="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="11*"/>
                    <RowDefinition Height="38*"/>
                    <RowDefinition Height="20*"/>
                    <RowDefinition Height="42*"/>
                    <RowDefinition Height="17*"/>
                    <RowDefinition Height="42*"/>
                    <RowDefinition Height="17*"/>
                    <RowDefinition Height="42*"/>
                    <RowDefinition Height="89*"/>
                    <RowDefinition Height="43*"/>
                    <RowDefinition Height="12*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="41*"/>
                    <ColumnDefinition Width="137*"/>
                    <ColumnDefinition Width="41*"/>
                </Grid.ColumnDefinitions>

                <Viewbox Margin="30,11,30,11" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="3">
                    <TextBlock Foreground="White" FontSize="1">
                    Jetons à aligner
                    </TextBlock>
                </Viewbox>

                <Border BorderBrush="White" Grid.Row="3" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave" Grid.Column="1">

                    <Viewbox>
                        <Button Background="Transparent" OverridesDefaultStyle="False" Click="Button_Click">
                            <Button.Template>
                                <ControlTemplate>
                                    <TextBlock Foreground="{DynamicResource ButtonTextColor}" Margin="2">
                                    3 jetons
                                    </TextBlock>
                                </ControlTemplate>
                            </Button.Template>

                        </Button>
                    </Viewbox>


                </Border>

                <Border BorderBrush="White" Grid.Row="5" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave" Grid.Column="1">

                    <Viewbox>
                        <Button Background="Transparent" OverridesDefaultStyle="False" Click="Button_Click">
                            <Button.Template>
                                <ControlTemplate>
                                    <TextBlock Foreground="{DynamicResource ButtonTextColor}" Margin="2">
    4 jetons
                                    </TextBlock>
                                </ControlTemplate>
                            </Button.Template>

                        </Button>
                    </Viewbox>


                </Border>

                <Border BorderBrush="White" Grid.Row="7" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave" Grid.Column="1">

                    <Viewbox>
                        <Button x:Name="btn5J" Background="Transparent" OverridesDefaultStyle="False" Click="Button_Click">
                            <Button.Template>
                                <ControlTemplate>
                                    <TextBlock Foreground="{DynamicResource ButtonTextColor}" Margin="2">
    5 jetons
                                    </TextBlock>
                                </ControlTemplate>
                            </Button.Template>

                        </Button>
                    </Viewbox>


                </Border>

                <Border BorderBrush="White" Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="3" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave" Margin="1,0,0,12" Grid.RowSpan="2">

                    <Viewbox>
                        <Button x:Name="btnApplique" Background="Transparent" OverridesDefaultStyle="False" Click="btnApplique_Click">
                            <Button.Template>
                                <ControlTemplate>
                                    <TextBlock Foreground="{DynamicResource ButtonTextColor}" Margin="4">
    Appliquer les paramètres
                                    </TextBlock>
                                </ControlTemplate>
                            </Button.Template>

                        </Button>
                    </Viewbox>


                </Border>



            </Grid>

            <Grid Grid.Row="4" Grid.Column="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="19*"/>
                    <RowDefinition Height="156*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Viewbox Grid.Column="0" Grid.Row="0">
                    <TextBlock Foreground="White">
            Limite de temps
                    </TextBlock>
                </Viewbox>

                <Grid Grid.Column="0" Grid.Row="1" Margin="0,5,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="35*"/>
                        <RowDefinition Height="7*"/>
                        <RowDefinition Height="35*"/>
                        <RowDefinition Height="7*"/>
                        <RowDefinition Height="35*"/>
                        <RowDefinition Height="7*"/>
                        <RowDefinition Height="35*"/>
                        <RowDefinition Height="7*"/>
                        <RowDefinition Height="35*"/>
                        <RowDefinition Height="7*"/>
                        <RowDefinition Height="35*"/>
                        <RowDefinition Height="19*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="21*"/>
                        <ColumnDefinition Width="133*"/>
                        <ColumnDefinition Width="21*"/>
                    </Grid.ColumnDefinitions>

                    <Border BorderBrush="White" Grid.Row="0" Grid.Column="1" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave">

                        <Viewbox>
                            <Button Background="Transparent" OverridesDefaultStyle="False" Click="Button_Click">
                                <Button.Template>
                                    <ControlTemplate>
                                        <TextBlock Foreground="{DynamicResource ButtonTextColor}" Margin="2">
                                Aucune
                                        </TextBlock>
                                    </ControlTemplate>
                                </Button.Template>

                            </Button>
                        </Viewbox>


                    </Border>

                    <Border BorderBrush="White" Grid.Row="2" Grid.Column="1" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave">

                        <Viewbox>
                            <Button Background="Transparent" OverridesDefaultStyle="False" Click="Button_Click">
                                <Button.Template>
                                    <ControlTemplate>
                                        <TextBlock Foreground="{DynamicResource ButtonTextColor}" Margin="4">
                10 secondes
                                        </TextBlock>
                                    </ControlTemplate>
                                </Button.Template>

                            </Button>
                        </Viewbox>


                    </Border>

                    <Border BorderBrush="White" Grid.Row="4" Grid.Column="1" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave">

                        <Viewbox>
                            <Button Background="Transparent" OverridesDefaultStyle="False" Click="Button_Click">
                                <Button.Template>
                                    <ControlTemplate>
                                        <TextBlock Foreground="{DynamicResource ButtonTextColor}" Margin="4">
                15 secondes
                                        </TextBlock>
                                    </ControlTemplate>
                                </Button.Template>

                            </Button>
                        </Viewbox>


                    </Border>

                    <Border BorderBrush="White" Grid.Row="6" Grid.Column="1" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave">

                        <Viewbox>
                            <Button Background="Transparent" OverridesDefaultStyle="False" Click="Button_Click">
                                <Button.Template>
                                    <ControlTemplate>
                                        <TextBlock Foreground="{DynamicResource ButtonTextColor}" Margin="4">
                30 secondes
                                        </TextBlock>
                                    </ControlTemplate>
                                </Button.Template>

                            </Button>
                        </Viewbox>


                    </Border>

                    <Border BorderBrush="White" Grid.Row="8" Grid.Column="1" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave">

                        <Viewbox>
                            <Button Background="Transparent" OverridesDefaultStyle="False" Click="Button_Click">
                                <Button.Template>
                                    <ControlTemplate>
                                        <TextBlock Foreground="{DynamicResource ButtonTextColor}" Margin="4">
                1 minute
                                        </TextBlock>
                                    </ControlTemplate>
                                </Button.Template>

                            </Button>
                        </Viewbox>


                    </Border>

                    <Border BorderBrush="White" Grid.Row="10" Grid.Column="1" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave">

                        <Viewbox>
                            <Button Background="Transparent" OverridesDefaultStyle="False" Click="Button_Click">
                                <Button.Template>
                                    <ControlTemplate>
                                        <TextBlock Foreground="{DynamicResource ButtonTextColor}" Margin="4">
                2 minutes
                                        </TextBlock>
                                    </ControlTemplate>
                                </Button.Template>

                            </Button>
                        </Viewbox>


                    </Border>

                </Grid>

            </Grid>

            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="5"
        Width="50" Height="50" CornerRadius="10"
        Background="{DynamicResource AccentColor}"
        Grid.Row="0" Grid.RowSpan="3" Grid.Column="6" Grid.ColumnSpan="2">
                <Button Background="Transparent" BorderThickness="0"
            FontSize="{DynamicResource FontSize22}" FontFamily="Agency FB"
            Content="✕" Cursor="Hand"
            OverridesDefaultStyle="True"
            Click="Button_retour"
            Foreground="{DynamicResource ButtonTextColor}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Border>

        </Grid>
    </Grid>

</Page>
