<Page x:Class="Interfaces.Pages.ParametreJeu"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Interfaces.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ParametreJeu" Background="#20114A" FontFamily="Agency FB">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="18*"/>
            <RowDefinition Height="25*"/>
            <RowDefinition Height="24*"/>
            <RowDefinition Height="9*"/>
            <RowDefinition Height="374*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60*"/>
            <ColumnDefinition Width="175*"/>
            <ColumnDefinition Width="51*"/>
            <ColumnDefinition Width="227*"/>
            <ColumnDefinition Width="51*"/>
            <ColumnDefinition Width="175*"/>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="56*"/>
        </Grid.ColumnDefinitions>

        <Viewbox Grid.Column="3" Grid.Row="1" Grid.RowSpan="2">
            <TextBlock Foreground="White">
                Paramètres
            </TextBlock>
        </Viewbox>

        <Grid Grid.Row="4" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="19*"/>
                <RowDefinition Height="156*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Viewbox Grid.Column="0" Grid.Row="0">
                <TextBlock Foreground="White">
                    Taille de la grille
                </TextBlock>
            </Viewbox>

            <Grid Grid.Column="0" Grid.Row="1" Margin="0,5,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="35*"/>
                    <RowDefinition Height="7*"/>
                    <RowDefinition Height="35*"/>
                    <RowDefinition Height="7*"/>
                    <RowDefinition Height="35*"/>
                    <RowDefinition Height="7*"/>
                    <RowDefinition Height="35*"/>
                    <RowDefinition Height="7*"/>
                    <RowDefinition Height="35*"/>
                    <RowDefinition Height="7*"/>
                    <RowDefinition Height="35*"/>
                    <RowDefinition Height="19*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="21*"/>
                    <ColumnDefinition Width="133*"/>
                    <ColumnDefinition Width="21*"/>
                </Grid.ColumnDefinitions>

                <Border BorderBrush="White" Grid.Row="0" Grid.Column="1" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave">

                    <Viewbox>
                        <Button x:Name="btn4" Background="Transparent" OverridesDefaultStyle="False" Click="Button_Click">
                            <Button.Template>
                                <ControlTemplate>
                                    <TextBlock Foreground="White">
                                        4 x 4
                                    </TextBlock>
                                </ControlTemplate>
                            </Button.Template>

                        </Button>
                    </Viewbox>


                </Border>

                <Border BorderBrush="White" Grid.Row="2" Grid.Column="1" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave">

                    <Viewbox>
                        <Button x:Name="btn5" Background="Transparent" OverridesDefaultStyle="False" Click="Button_Click">
                            <Button.Template>
                                <ControlTemplate>
                                    <TextBlock Foreground="White">
                        5 x 5
                                    </TextBlock>
                                </ControlTemplate>
                            </Button.Template>

                        </Button>
                    </Viewbox>


                </Border>

                <Border BorderBrush="White" Grid.Row="4" Grid.Column="1" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave">

                    <Viewbox>
                        <Button Background="Transparent" OverridesDefaultStyle="False" Click="Button_Click">
                            <Button.Template>
                                <ControlTemplate>
                                    <TextBlock Foreground="White">
                        6 x 7
                                    </TextBlock>
                                </ControlTemplate>
                            </Button.Template>

                        </Button>
                    </Viewbox>


                </Border>

                <Border BorderBrush="White" Grid.Row="6" Grid.Column="1" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave">

                    <Viewbox>
                        <Button Background="Transparent" OverridesDefaultStyle="False" Click="Button_Click">
                            <Button.Template>
                                <ControlTemplate>
                                    <TextBlock Foreground="White">
                        8 x 7
                                    </TextBlock>
                                </ControlTemplate>
                            </Button.Template>

                        </Button>
                    </Viewbox>


                </Border>

                <Border BorderBrush="White" Grid.Row="8" Grid.Column="1" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave">

                    <Viewbox>
                        <Button Background="Transparent" OverridesDefaultStyle="False" Click="Button_Click">
                            <Button.Template>
                                <ControlTemplate>
                                    <TextBlock Foreground="White">
                        8 x 8
                                    </TextBlock>
                                </ControlTemplate>
                            </Button.Template>

                        </Button>
                    </Viewbox>


                </Border>

                <Border BorderBrush="White" Grid.Row="10" Grid.Column="1" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave">

                    <Viewbox>
                        <Button Background="Transparent" OverridesDefaultStyle="False" Click="Button_Click">
                            <Button.Template>
                                <ControlTemplate>
                                    <TextBlock Foreground="White">
                        10 x 10
                                    </TextBlock>
                                </ControlTemplate>
                            </Button.Template>

                        </Button>
                    </Viewbox>


                </Border>



            </Grid>

        </Grid>

        <Grid Grid.Column="3" Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="11*"/>
                <RowDefinition Height="38*"/>
                <RowDefinition Height="20*"/>
                <RowDefinition Height="42*"/>
                <RowDefinition Height="17*"/>
                <RowDefinition Height="42*"/>
                <RowDefinition Height="17*"/>
                <RowDefinition Height="42*"/>
                <RowDefinition Height="89*"/>
                <RowDefinition Height="43*"/>
                <RowDefinition Height="12*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="41*"/>
                <ColumnDefinition Width="137*"/>
                <ColumnDefinition Width="41*"/>
            </Grid.ColumnDefinitions>

            <Viewbox Margin="4,11,0,0" Grid.RowSpan="2" Grid.Column="1">
                <TextBlock Foreground="White">
                    Jetons à aligner
                </TextBlock>
            </Viewbox>

            <Border BorderBrush="White" Grid.Row="2" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave" Margin="4,20,0,0" Grid.RowSpan="2" Grid.Column="1">

                <Viewbox>
                    <Button Background="Transparent" OverridesDefaultStyle="False" Click="Button_Click">
                        <Button.Template>
                            <ControlTemplate>
                                <TextBlock Foreground="White">
                3 jetons
                                </TextBlock>
                            </ControlTemplate>
                        </Button.Template>

                    </Button>
                </Viewbox>


            </Border>

            <Border BorderBrush="White" Grid.Row="5" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave" Grid.Column="1">

                <Viewbox>
                    <Button Background="Transparent" OverridesDefaultStyle="False" Click="Button_Click">
                        <Button.Template>
                            <ControlTemplate>
                                <TextBlock Foreground="White">
    4 jetons
                                </TextBlock>
                            </ControlTemplate>
                        </Button.Template>

                    </Button>
                </Viewbox>


            </Border>

            <Border BorderBrush="White" Grid.Row="7" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave" Margin="4,0,0,1" Grid.Column="1">

                <Viewbox>
                    <Button x:Name="btn5J" Background="Transparent" OverridesDefaultStyle="False" Click="Button_Click">
                        <Button.Template>
                            <ControlTemplate>
                                <TextBlock Foreground="White">
    5 jetons
                                </TextBlock>
                            </ControlTemplate>
                        </Button.Template>

                    </Button>
                </Viewbox>


            </Border>

            <Border BorderBrush="White" Grid.Row="9" Grid.Column="1" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave" Margin="1,0,0,12" Grid.RowSpan="2">

                <Viewbox Width="165">
                    <Button x:Name="btnApplique" Background="Transparent" OverridesDefaultStyle="False" Click="btnApplique_Click">
                        <Button.Template>
                            <ControlTemplate>
                                <TextBlock Foreground="White">
    Appliquer les paramètres
                                </TextBlock>
                            </ControlTemplate>
                        </Button.Template>

                    </Button>
                </Viewbox>


            </Border>



        </Grid>

        <Grid Grid.Row="4" Grid.Column="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="19*"/>
                <RowDefinition Height="156*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Viewbox Grid.Column="0" Grid.Row="0">
                <TextBlock Foreground="White">
            Limite de temps
                </TextBlock>
            </Viewbox>

            <Grid Grid.Column="0" Grid.Row="1" Margin="0,5,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="35*"/>
                    <RowDefinition Height="7*"/>
                    <RowDefinition Height="35*"/>
                    <RowDefinition Height="7*"/>
                    <RowDefinition Height="35*"/>
                    <RowDefinition Height="7*"/>
                    <RowDefinition Height="35*"/>
                    <RowDefinition Height="7*"/>
                    <RowDefinition Height="35*"/>
                    <RowDefinition Height="7*"/>
                    <RowDefinition Height="35*"/>
                    <RowDefinition Height="19*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="21*"/>
                    <ColumnDefinition Width="133*"/>
                    <ColumnDefinition Width="21*"/>
                </Grid.ColumnDefinitions>

                <Border BorderBrush="White" Grid.Row="0" Grid.Column="1" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave">

                    <Viewbox>
                        <Button Background="Transparent" OverridesDefaultStyle="False" Click="Button_Click">
                            <Button.Template>
                                <ControlTemplate>
                                    <TextBlock Foreground="White">
                                Aucune
                                    </TextBlock>
                                </ControlTemplate>
                            </Button.Template>

                        </Button>
                    </Viewbox>


                </Border>

                <Border BorderBrush="White" Grid.Row="2" Grid.Column="1" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave">

                    <Viewbox Width="130">
                        <Button Background="Transparent" OverridesDefaultStyle="False" Click="Button_Click">
                            <Button.Template>
                                <ControlTemplate>
                                    <TextBlock Foreground="White">
                10 secondes
                                    </TextBlock>
                                </ControlTemplate>
                            </Button.Template>

                        </Button>
                    </Viewbox>


                </Border>

                <Border BorderBrush="White" Grid.Row="4" Grid.Column="1" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave">

                    <Viewbox Width="130">
                        <Button Background="Transparent" OverridesDefaultStyle="False" Click="Button_Click">
                            <Button.Template>
                                <ControlTemplate>
                                    <TextBlock Foreground="White">
                15 secondes
                                    </TextBlock>
                                </ControlTemplate>
                            </Button.Template>

                        </Button>
                    </Viewbox>


                </Border>

                <Border BorderBrush="White" Grid.Row="6" Grid.Column="1" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave">

                    <Viewbox Width="130">
                        <Button Background="Transparent" OverridesDefaultStyle="False" Click="Button_Click">
                            <Button.Template>
                                <ControlTemplate>
                                    <TextBlock Foreground="White">
                30 secondes
                                    </TextBlock>
                                </ControlTemplate>
                            </Button.Template>

                        </Button>
                    </Viewbox>


                </Border>

                <Border BorderBrush="White" Grid.Row="8" Grid.Column="1" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave">

                    <Viewbox>
                        <Button Background="Transparent" OverridesDefaultStyle="False" Click="Button_Click">
                            <Button.Template>
                                <ControlTemplate>
                                    <TextBlock Foreground="White">
                1 minute
                                    </TextBlock>
                                </ControlTemplate>
                            </Button.Template>

                        </Button>
                    </Viewbox>


                </Border>

                <Border BorderBrush="White" Grid.Row="10" Grid.Column="1" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave">

                    <Viewbox>
                        <Button Background="Transparent" OverridesDefaultStyle="False" Click="Button_Click">
                            <Button.Template>
                                <ControlTemplate>
                                    <TextBlock Foreground="White">
                2 minutes
                                    </TextBlock>
                                </ControlTemplate>
                            </Button.Template>

                        </Button>
                    </Viewbox>


                </Border>

            </Grid>

        </Grid>

        <Border BorderBrush="White" Grid.Row="0" Grid.RowSpan="2" Grid.Column="7" CornerRadius="20" Background="#8176A8" MouseEnter="Border_MouseEnter" Tag="#8176A8" MouseLeave="Border_MouseLeave" Margin="5,5,5,5">

            <Viewbox>
                <Button Background="Transparent" OverridesDefaultStyle="False">
                    <Button.Template>
                        <ControlTemplate>
                            <TextBlock Foreground="White" FontFamily="Arial Rounded MT Bold">
X
                            </TextBlock>
                        </ControlTemplate>
                    </Button.Template>

                </Button>
            </Viewbox>


        </Border>


    </Grid>
</Page>
