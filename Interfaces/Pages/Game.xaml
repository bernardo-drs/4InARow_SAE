<Page x:Class="Interfaces.Pages.Game"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Interfaces.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Game"
      Background="{DynamicResource BackgroundColor}"
      FontFamily="Agency FB">

    <Grid Grid.IsSharedSizeScope="True">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100*"/>
            <ColumnDefinition Width="85*"/>
            <ColumnDefinition Width="73*"/>
            <ColumnDefinition Width="260*"/>
            <ColumnDefinition Width="56*"/>
            <ColumnDefinition Width="85*"/>
            <ColumnDefinition Width="100*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="20*"/>
            <RowDefinition Height="53*"/>
            <RowDefinition Height="33*"/>
            <RowDefinition Height="25*"/>
            <RowDefinition Height="50*"/>
            <RowDefinition Height="124*"/>
            <RowDefinition Height="80*"/>
            <RowDefinition Height="35*"/>
            <RowDefinition Height="45*"/>
        </Grid.RowDefinitions>
        <Border Background="#004aad" Grid.RowSpan="3" Grid.Row="4" Grid.Column="3" CornerRadius="10">
            <Grid x:Name="GameGrid" Margin="10">

            </Grid>
        </Border>
        <Border Background="#004aad" Grid.Row="5" Grid.Column="1" CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="16*"/>
                    <ColumnDefinition Width="40*"/>
                    <ColumnDefinition Width="17*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="8*"/>
                    <RowDefinition Height="57*"/>
                    <RowDefinition Height="7*"/>
                    <RowDefinition Height="40*"/>
                    <RowDefinition Height="8*"/>
                </Grid.RowDefinitions>
                <Viewbox Grid.Column="1" Grid.Row="1">
                    <TextBlock Foreground="#FAFAFA" Text="XX"/>
                </Viewbox>
                <Ellipse x:Name="Player1Forme" Grid.Column="1" Grid.Row="3" Fill="{StaticResource ColorButtonStyle}"/>
            </Grid>
        </Border>
    </Grid>
</Page>
