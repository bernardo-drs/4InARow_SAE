<Page x:Class="Interfaces.Pages.ParametresIA"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Page.Resources>

        <Style x:Key="ColorButton" TargetType="Button">
            <Setter Property="Width"           Value="42"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Margin"          Value="4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Tag"             Value="unselected"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="Ring" Width="42" Height="42"
                                     Fill="Transparent" StrokeThickness="0"/>
                            <Ellipse Width="34" Height="34"
                                     Fill="{TemplateBinding Background}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Ring" Property="Stroke" Value="White"/>
                                <Setter TargetName="Ring" Property="StrokeThickness" Value="2"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="selected">
                                <Setter TargetName="Ring" Property="Stroke" Value="White"/>
                                <Setter TargetName="Ring" Property="StrokeThickness" Value="3"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DiffButton" TargetType="Button">
            <Setter Property="Width"           Value="90"/>
            <Setter Property="Height"          Value="90"/>
            <Setter Property="Margin"          Value="6,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Tag"             Value="unselected"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14"
                                BorderBrush="Transparent"
                                BorderThickness="0">
                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                <TextBlock x:Name="Label"
                                           Text="{TemplateBinding Content}"
                                           Foreground="White"
                                           FontFamily="Baskerville Old Face"
                                           FontSize="{DynamicResource FontSize12}" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,4"/>
                                <TextBlock x:Name="Emoji"
                                           Text="{TemplateBinding ToolTip}"
                                           FontSize="36"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="White"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="selected">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="White"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="3"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>

    <Viewbox Stretch="Uniform" Width="420" Height="400">
        <Grid Width="420">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Information du bot"
                       FontFamily="Baskerville Old Face"
                       Foreground="White" FontSize="{DynamicResource FontSize22}"
                       TextAlignment="Center" Margin="0,0,0,14"/>

            <StackPanel Grid.Row="1" Margin="0,0,0,16">
                <TextBlock Text="Difficulté"
                           FontFamily="Baskerville Old Face"
                           Foreground="White" FontSize="{DynamicResource FontSize17}"
                           FontWeight="Bold" Margin="4,0,0,10"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="BtnFacile"
                            Style="{StaticResource DiffButton}"
                            Background="#27AE60"
                            Tag="unselected"
                            Content="Facile"
                            ToolTip="😊"
                            Click="DiffButton_Click"/>
                    <Button x:Name="BtnMoyen"
                            Style="{StaticResource DiffButton}"
                            Background="#F39C12"
                            Tag="unselected"
                            Content="Moyen"
                            ToolTip="😐"
                            Click="DiffButton_Click"/>
                    <Button x:Name="BtnDifficile"
                            Style="{StaticResource DiffButton}"
                            Background="#C0392B"
                            Tag="unselected"
                            Content="Difficile"
                            ToolTip="😠"
                            Click="DiffButton_Click"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="2" VerticalAlignment="Top" Margin="0,4,0,0">
                <TextBlock Text="Couleur des jetons"
                           FontFamily="Baskerville Old Face"
                           Foreground="White" FontSize="{DynamicResource FontSize17}" Margin="4,0,0,6"/>
                <Border Background="#4A4470" CornerRadius="12" Padding="8,6"
                        HorizontalAlignment="Center">
                    <UniformGrid Columns="4" Rows="2">
                        <Button Style="{StaticResource ColorButton}" Background="#E53935" Tag="unselected" Click="ColorButton_Click"/>
                        <Button Style="{StaticResource ColorButton}" Background="#E91E8C" Tag="unselected" Click="ColorButton_Click"/>
                        <Button Style="{StaticResource ColorButton}" Background="#1A1A1A" Tag="unselected" Click="ColorButton_Click"/>
                        <Button Style="{StaticResource ColorButton}" Background="#7B1FA2" Tag="unselected" Click="ColorButton_Click"/>
                        <Button Style="{StaticResource ColorButton}" Background="#FDD835" Tag="unselected" Click="ColorButton_Click"/>
                        <Button Style="{StaticResource ColorButton}" Background="#43A047" Tag="unselected" Click="ColorButton_Click"/>
                        <Button Style="{StaticResource ColorButton}" Background="#EEEEEE" Tag="unselected" Click="ColorButton_Click"/>
                        <Button Style="{StaticResource ColorButton}" Background="#FF6F00" Tag="unselected" Click="ColorButton_Click"/>
                    </UniformGrid>
                </Border>
            </StackPanel>

        </Grid>
    </Viewbox>
</Page>