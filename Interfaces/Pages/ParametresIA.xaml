<Page x:Class="Interfaces.Pages.ParametresIA"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <Page.Resources>

        <Style x:Key="ColorButton" TargetType="Button">
            <Setter Property="Width"           Value="42"/>
            <Setter Property="Height"          Value="42"/>
            <Setter Property="Margin"          Value="4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Tag"             Value="unselected"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="Ring" Width="42" Height="42"
                                     Fill="Transparent" StrokeThickness="0"/>
                            <Ellipse Width="34" Height="34"
                                     Fill="{TemplateBinding Background}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Ring" Property="Stroke" Value="White"/>
                                <Setter TargetName="Ring" Property="StrokeThickness" Value="2"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="selected">
                                <Setter TargetName="Ring" Property="Stroke" Value="White"/>
                                <Setter TargetName="Ring" Property="StrokeThickness" Value="3"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DiffButton" TargetType="Button">
            <Setter Property="Width"           Value="90"/>
            <Setter Property="Height"          Value="90"/>
            <Setter Property="Margin"          Value="6,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Tag"             Value="unselected"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14"
                                BorderBrush="Transparent"
                                BorderThickness="0">
                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                <TextBlock x:Name="Label"
                                           Text="{TemplateBinding Content}"
                                           Foreground="White"
                                           FontFamily="Baskerville Old Face"
                                           FontSize="{DynamicResource FontSize12}" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,4"/>
                                <TextBlock x:Name="Emoji"
                                           Text="{TemplateBinding ToolTip}"
                                           FontSize="36"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="White"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="selected">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="White"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="3"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>

    <Viewbox Stretch="Uniform" Width="420" Height="400">
        <Grid Width="420" Margin="0,-50,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Information du bot"
                       FontFamily="Agency FB"
                       Foreground="White" FontSize="{DynamicResource FontSize22}"
                       TextAlignment="Center" Margin="0,-10,0,14"/>

            <StackPanel Grid.Row="1" Margin="0,0,0,16">
                <TextBlock Text="Difficulté"
                           FontFamily="Agency FB"
                           Foreground="White" FontSize="{DynamicResource FontSize17}" Margin="4,0,0,6"/>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="BtnFacile"
                            Style="{StaticResource DiffButton}"
                            Background="#27AE60"
                            Tag="unselected"
                            Content="Facile"
                            ToolTip="😊"
                            Click="DiffButton_Click"/>
                    <Button x:Name="BtnMoyen"
                            Style="{StaticResource DiffButton}"
                            Background="#F39C12"
                            Tag="unselected"
                            Content="Moyen"
                            ToolTip="😐"
                            Click="DiffButton_Click"/>
                    <Button x:Name="BtnDifficile"
                            Style="{StaticResource DiffButton}"
                            Background="#C0392B"
                            Tag="unselected"
                            Content="Difficile"
                            ToolTip="😠"
                            Click="DiffButton_Click"
                            />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="2" VerticalAlignment="Top" Margin="0,4,0,0">
                <Grid HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#4A4470" CornerRadius="12" Padding="8,6">
                        <UniformGrid Columns="4" Rows="2">
                            <Button Style="{StaticResource ColorButton}" Background="#ff3131" Tag="unselected" Click="ColorButton_Click"/>
                            <Button Style="{StaticResource ColorButton}" Background="#ff66c4" Tag="unselected" Click="ColorButton_Click"/>
                            <Button Style="{StaticResource ColorButton}" Background="#000000" Tag="unselected" Click="ColorButton_Click"/>
                            <Button Style="{StaticResource ColorButton}" Background="#5e17eb" Tag="unselected" Click="ColorButton_Click"/>
                            <Button Style="{StaticResource ColorButton}" Background="#ffde59" Tag="unselected" Click="ColorButton_Click"/>
                            <Button Style="{StaticResource ColorButton}" Background="#7ed957" Tag="unselected" Click="ColorButton_Click"/>
                            <Button Style="{StaticResource ColorButton}" Background="#ffffff" Tag="unselected" Click="ColorButton_Click"/>
                            <Button Style="{StaticResource ColorButton}" Background="#ff751f" Tag="unselected" Click="ColorButton_Click"/>
                        </UniformGrid>
                    </Border>
                    <TextBlock x:Name="IconErrCoulIA" x:FieldModifier="public"
                               Grid.Column="1"
                               Text="⚠" Foreground="#E53935"
                               FontSize="{DynamicResource FontSize17}" VerticalAlignment="Center"
                               Margin="8,0,0,0" Visibility="Hidden"
                               Tag="Error"/>
                </Grid>

                <TextBlock x:Name="ErrCoulIA" x:FieldModifier="public"
                           Foreground="#E53935" FontSize="12"
                           FontFamily="Segoe UI" FontStyle="Italic"
                           HorizontalAlignment="Center" Margin="0,4,0,0"
                           Height="18" Visibility="Hidden"
                           Tag="Error"/>
            </StackPanel>

        </Grid>
    </Viewbox>
</Page>