<Page x:Class="Interfaces.Pages.IAOrHuman"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Interfaces.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="IAOrHuman" Background="#20114A" FontFamily="Agency FB">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="79*"/>
            <RowDefinition Height="273*"/>
            <RowDefinition Height="79*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="155*"/>
            <ColumnDefinition Width="189*"/>
            <ColumnDefinition Width="107*"/>
            <ColumnDefinition Width="189*"/>
            <ColumnDefinition Width="155*"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="1" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="56*"/>
                <RowDefinition Height="35*"/>
                <RowDefinition Height="156*"/>
                <RowDefinition Height="38*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="17*"/>
                <ColumnDefinition Width="56*"/>
                <ColumnDefinition Width="17*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="3" Grid.RowSpan="4" BorderThickness="0" Background="Transparent" OverridesDefaultStyle="True">

            </Button>

            <Viewbox Grid.Column="1" >
                <TextBlock Foreground="White">
                Affronter l'IA
                </TextBlock>
            </Viewbox>

            <Viewbox Grid.Column="1" Grid.Row="2">
                <TextBlock>
                    djizohd
                </TextBlock>
            </Viewbox>

        </Grid>

        <Grid Grid.Column="3" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="56*"/>
                <RowDefinition Height="35*"/>
                <RowDefinition Height="156*"/>
                <RowDefinition Height="38*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="17*"/>
                <ColumnDefinition Width="56*"/>
                <ColumnDefinition Width="17*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="3" Grid.RowSpan="4" BorderThickness="0" Background="Transparent" OverridesDefaultStyle="True">

            </Button>

            <Viewbox Grid.Column="1" >
                <TextBlock Foreground="White">
                    Affronter un joueur
                </TextBlock>
            </Viewbox>

            <Viewbox Grid.Column="1" Grid.Row="2">
                <TextBlock>
                    djizohd
                </TextBlock>
            </Viewbox>
        </Grid>

    </Grid>
</Page>
