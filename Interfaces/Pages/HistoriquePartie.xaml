                                                            <Border Background="#FFFFFF" CornerRadius="4" Width="6" Height="Auto"/>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>
                                        </Track>
