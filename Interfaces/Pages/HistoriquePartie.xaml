                            <TextBlock Text="4" FontSize="10"  Grid.Row="2" Grid.Column="4" Foreground="#ff66c4" VerticalAlignment="Center"/>
                            <!--Statue de la partie-->
                            <TextBlock Text="En cours" FontSize="10" Grid.RowSpan="2" Grid.Row="1" Grid.Column="5" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#ffffff"/>
                            <!--Informations de la partie-->
                            <TextBlock Text="Challenge" FontSize="10"  Grid.Row="1" Grid.Column="6" HorizontalAlignment="Center" Foreground="#ffffff" VerticalAlignment="Center"/>
                            <TextBlock Text="3/19/2026" FontSize="10"  Grid.Row="2" Grid.Column="6" HorizontalAlignment="Center" Foreground="#ffffff" VerticalAlignment="Center"/>
                        </Grid>
