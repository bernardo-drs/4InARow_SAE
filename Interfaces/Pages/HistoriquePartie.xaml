<Page x:Class="Interfaces.Pages.HistoriquePartie"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Interfaces.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="HistoriquePartie"
      Background="#20114a">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="19*"/>
            <RowDefinition Height="40*"/>
            <RowDefinition Height="372*"/>
            <RowDefinition Height="19*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="62*"/>
            <ColumnDefinition Width="143*"/>
            <ColumnDefinition Width="391*"/>
            <ColumnDefinition Width="205*"/>
        </Grid.ColumnDefinitions>

        <!--Bouton retour en arrière-->

        <Border x:Name="ExitHistorique" Background="#8176a8" CornerRadius="10" Grid.Row="0" Grid.RowSpan="2" Margin="5,5,5,5">
            <Button x:Name="BtnRetour" Click="OnLeavePage" Background="Transparent">
                <TextBlock Text="X" FontSize="30" Foreground="#ffffff" FontFamily="Arial Rounded MT Bold"></TextBlock>
            </Button>
        </Border>

        <!--Affichage de l'historique des parties-->

        <Border CornerRadius="15"  Grid.Row="1" Grid.RowSpan="2" Grid.Column="2" Background="#004aad"></Border>

        <Grid Grid.Column="2" Grid.RowSpan="2" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="11*"/>
                <RowDefinition Height="45*"/>
                <RowDefinition Height="21*"/>
                <RowDefinition Height="359*"/>
                <RowDefinition Height="21*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="27*"/>
                <ColumnDefinition Width="26*"/>
                <ColumnDefinition Width="353*"/>
                <ColumnDefinition Width="26*"/>
                <ColumnDefinition Width="27*"/>
            </Grid.ColumnDefinitions>

            <Border CornerRadius="12"  Grid.Row="1" Grid.Column="2" Background="#20114a">
                <TextBlock Text="Historique" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30" Foreground="#ffffff" FontFamily="Agency FB"/>
            </Border>

